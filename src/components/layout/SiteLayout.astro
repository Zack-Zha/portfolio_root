---
// SiteLayout.astro — Global layout shell with desktop scaling
import Header from './Header.astro';
import Footer from './Footer.astro';
import MobilePlaceholder from './MobilePlaceholder.astro';
import MobileHome from '../mobile/MobileHome.astro';
import '../../styles/global.css';
import '../../styles/animations.css';

export interface Props {
  title?: string;
  showAmbient?: boolean;
  isHome?: boolean;
}

const { title = 'Portfolio', showAmbient = false, isHome = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="cn" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <!-- Desktop layout -->
    <div id="desktop-layout" class="desktop-layout">
      <Header />

      <div id="desktop-scale-host" class="desktop-scale-host">
        <div id="desktop-stage" class="desktop-stage">
          {showAmbient && <div class="hero-ambient"></div>}

          <main class="desktop-canvas font-geist text-black relative z-10 flex flex-col gap-[120px] shrink-0">
            <slot />
            <Footer />
          </main>
        </div>
      </div>
    </div>

    <!-- Mobile layout -->
    <div id="mobile-layout" class="mobile-layout">
      {isHome ? <MobileHome /> : <MobilePlaceholder />}
    </div>

    <script>
      const DESIGN_WIDTH = 1920;
      const MOBILE_BREAKPOINT = 768;

      function syncDesktopScale() {
        const host = document.getElementById('desktop-scale-host');
        const stage = document.getElementById('desktop-stage');
        if (!host || !stage) return;

        const width = window.innerWidth;
        if (width <= MOBILE_BREAKPOINT) return;

        const scale = Math.min(1, width / DESIGN_WIDTH);
        document.documentElement.style.setProperty('--desktop-scale', String(scale));

        requestAnimationFrame(() => {
          host.style.height = (stage.scrollHeight * scale) + 'px';
        });
      }

      syncDesktopScale();
      window.addEventListener('resize', syncDesktopScale);

      if ('ResizeObserver' in window) {
        const stage = document.getElementById('desktop-stage');
        if (stage) {
          new ResizeObserver(syncDesktopScale).observe(stage);
        }
      }
    </script>
  </body>
</html>
