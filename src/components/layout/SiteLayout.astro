---
// SiteLayout.astro — Global layout shell with desktop and mobile scaling
import Header from './Header.astro';
import Footer from './Footer.astro';
import MobilePlaceholder from './MobilePlaceholder.astro';
import MobileNavbar from '../mobile/MobileNavbar.astro';
import MobileHomeContent from '../mobile/MobileHomeContent.astro';
import '../../styles/global.css';
import '../../styles/animations.css';

export interface Props {
  title?: string;
  showAmbient?: boolean;
  isHome?: boolean;
}

const { title = 'Portfolio', showAmbient = false, isHome = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="cn" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <!-- Desktop layout -->
    <div id="desktop-layout" class="desktop-layout">
      <Header />

      <div id="desktop-scale-host" class="desktop-scale-host">
        <div id="desktop-stage" class="desktop-stage">
          {showAmbient && <div class="hero-ambient"></div>}

          <main class="desktop-canvas font-geist text-black relative z-10 flex flex-col gap-[120px] shrink-0">
            <slot />
            <Footer />
          </main>
        </div>
      </div>
    </div>

    <!-- Mobile layout -->
    <div id="mobile-layout" class="mobile-layout">
      <div class="mobile-navbar-host">
        <div class="mobile-navbar-stage">
          {isHome && <MobileNavbar />}
        </div>
      </div>
      <div id="mobile-scale-host" class="mobile-scale-host">
        <div id="mobile-stage" class="mobile-stage">
          {isHome ? <MobileHomeContent /> : <MobilePlaceholder />}
        </div>
      </div>
    </div>

    <script>
      const DESKTOP_DESIGN_WIDTH = 1920;
      const MOBILE_DESIGN_WIDTH = 768;
      const MOBILE_BREAKPOINT = 768;

      function syncDesktopScale() {
        const host = document.getElementById('desktop-scale-host');
        const stage = document.getElementById('desktop-stage');
        const header = document.getElementById('desktop-header');
        if (!host || !stage) return;

        const width = window.innerWidth;
        if (width <= MOBILE_BREAKPOINT) return;

        const scale = Math.min(1, width / DESKTOP_DESIGN_WIDTH);
        document.documentElement.style.setProperty('--desktop-scale', String(scale));

        requestAnimationFrame(() => {
          host.style.height = (stage.scrollHeight * scale) + 'px';
          if (header) {
            const frame = header.querySelector('.desktop-header-frame');
            if (frame) {
              header.style.height = (frame.scrollHeight * scale) + 'px';
            }
          }
        });
      }

      function syncMobileScale() {
        const host = document.getElementById('mobile-scale-host');
        const stage = document.getElementById('mobile-stage');
        const navbarHost = document.querySelector('.mobile-navbar-host');

        const width = window.innerWidth;
        if (width > MOBILE_BREAKPOINT) return;

        const scale = Math.min(1, width / MOBILE_DESIGN_WIDTH);
        document.documentElement.style.setProperty('--mobile-scale', String(scale));

        requestAnimationFrame(() => {
          if (host && stage) {
            host.style.height = (stage.scrollHeight * scale) + 'px';
          }
          if (navbarHost) {
            const navbarStage = navbarHost.querySelector('.mobile-navbar-stage');
            if (navbarStage) {
              const height = navbarStage.scrollHeight || 144;
              navbarHost.style.height = (height * scale) + 'px';
            }
          }
        });
      }

      syncDesktopScale();
      syncMobileScale();

      window.addEventListener('resize', () => {
        syncDesktopScale();
        syncMobileScale();
      });

      if ('ResizeObserver' in window) {
        const desktopStage = document.getElementById('desktop-stage');
        if (desktopStage) {
          new ResizeObserver(syncDesktopScale).observe(desktopStage);
        }

        const mobileStage = document.getElementById('mobile-stage');
        if (mobileStage) {
          new ResizeObserver(syncMobileScale).observe(mobileStage);
        }

        const navbarStage = document.querySelector('.mobile-navbar-stage');
        if (navbarStage) {
          new ResizeObserver(syncMobileScale).observe(navbarStage);
        }
      }
    </script>
  </body>
</html>
