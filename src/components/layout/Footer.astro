---
// Footer.astro — Site footer
import { t, l } from '@/i18n/home';
import type { Locale } from '@/i18n/home';

export interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const tagline = t.footer.tagline.en;
const name = t.footer.name.en;
---

<footer class="w-full">
  <div class="w-full flex items-center justify-between px-20 py-6">
    <div class="text-[20px] leading-[1.3em]">{name} &copy; <span id="copyright-year">2025</span></div>
    <div class="flex items-center gap-[64px]">
      <div class="text-[20px] leading-[1.3em]">{tagline}</div>
    </div>
  </div>
</footer>

<script>
  document.getElementById('copyright-year').textContent = new Date().getFullYear();
</script>
