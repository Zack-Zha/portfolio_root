---
// Header.astro — Fixed navigation bar with desktop scaling + language switch
import { t, l } from '@/i18n/home';
import type { Locale } from '@/i18n/home';

export interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const isEn = locale === 'en';
const name = l(t.header.name, locale);
const workText = l(t.header.work, locale);
const galleryText = l(t.header.gallery, locale);
const aboutText = l(t.header.about, locale);
const workHref = isEn ? '#work' : '/zh/#work';
---

<header id="desktop-header" class="fixed top-0 left-0 right-0 z-50 bg-[rgba(237,237,237,0.5)] backdrop-blur-[50px] overflow-hidden">
  <div class="desktop-header-frame w-[1920px] flex items-center justify-between px-20 py-6">
    <div
      id="homeTitle"
      class="text-xl font-medium leading-[1.3em] cursor-pointer transition-colors duration-[400ms] ease-[cubic-bezier(.4,0,.2,1)] hover:text-black/50"
    >
      {name}
    </div>
    <nav class="flex items-center gap-16 text-xl font-medium leading-[1.3em]">
      <a
        href={workHref}
        class="transition-colors duration-[400ms] ease-[cubic-bezier(.4,0,.2,1)] hover:text-black/90 text-black/50"
      >
        {workText}
      </a>
      <a
        href="/gallery"
        class="transition-colors duration-[400ms] ease-[cubic-bezier(.4,0,.2,1)] hover:text-black/90 text-black/50"
      >
        {galleryText}
      </a>
      <a
        href="/about"
        class="transition-colors duration-[400ms] ease-[cubic-bezier(.4,0,.2,1)] hover:text-black/90 text-black/50"
      >
        {aboutText}
      </a>
      <!-- Language switch -->
      <span class="flex items-center gap-0">
        <a
          href="/"
          class="transition-colors duration-[400ms] ease-[cubic-bezier(.4,0,.2,1)] hover:text-black/90"
          class:list={[isEn ? 'text-black/90' : 'text-black/50']}
        >EN</a>
        <span class="text-black/50">&nbsp;/&nbsp;</span>
        <a
          href="/zh/"
          class="transition-colors duration-[400ms] ease-[cubic-bezier(.4,0,.2,1)] hover:text-black/90"
          class:list={[isEn ? 'text-black/50' : 'text-black/90']}
          style={locale === 'zh' ? 'font-family: var(--font-zh);' : ''}
        >中文</a>
      </span>
    </nav>
  </div>
</header>

<style>
  .desktop-header-frame {
    position: relative;
    left: 50%;
    transform: translateX(-50%) scale(var(--desktop-scale));
    transform-origin: top center;
  }

  @media (max-width: 768px) {
    header {
      display: none;
    }
  }
</style>

<script>
  const ht = document.getElementById('homeTitle');
  if (ht) {
    ht.addEventListener('click', () => {
      const path = window.location.pathname.replace(/\/+$/, '');
      if (path === '' || path === '/' || path === '/zh') {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } else {
        window.location.href = '/';
      }
    });
  }
</script>
