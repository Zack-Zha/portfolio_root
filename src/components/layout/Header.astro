---
// Header.astro — Fixed navigation bar with desktop scaling
---

<header id="desktop-header" class="fixed top-0 left-0 right-0 z-50 bg-[rgba(237,237,237,0.2)] backdrop-blur-[24px] overflow-hidden">
  <div class="desktop-header-frame w-[1920px] flex items-center justify-between px-20 py-6">
    <div
      id="homeTitle"
      class="text-xl font-medium leading-[1.3em] cursor-pointer transition-colors duration-[400ms] ease-[cubic-bezier(.4,0,.2,1)] hover:text-black/50"
    >
      Chengke Zha
    </div>
    <nav class="flex items-center gap-16 text-black/50 text-xl font-medium leading-[1.3em]">
      <a
        href="#work"
        class="transition-colors duration-[400ms] ease-[cubic-bezier(.4,0,.2,1)] hover:text-black/90"
      >
        Work
      </a>
      <a
        href="/gallery"
        class="transition-colors duration-[400ms] ease-[cubic-bezier(.4,0,.2,1)] hover:text-black/90"
      >
        Gallery
      </a>
      <a
        href="/about"
        class="transition-colors duration-[400ms] ease-[cubic-bezier(.4,0,.2,1)] hover:text-black/90"
      >
        About
      </a>
    </nav>
  </div>
</header>

<style>
  .desktop-header-frame {
    position: relative;
    left: 50%;
    transform: translateX(-50%) scale(var(--desktop-scale));
    transform-origin: top center;
  }

  @media (max-width: 768px) {
    header {
      display: none;
    }
  }
</style>

<script>
  const ht = document.getElementById('homeTitle');
  if (ht) {
    ht.addEventListener('click', () => {
      const path = window.location.pathname.replace(/\/+$/, '');
      if (path === '' || path === '/') {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } else {
        window.location.href = '/';
      }
    });
  }
</script>
