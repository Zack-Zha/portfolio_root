---
// SystemResearchSection.astro — System + Research side-by-side
import ProjectInfoRow from '@/components/common/ProjectInfoRow.astro';
import { t, l } from '@/i18n/home';
import type { Locale } from '@/i18n/home';

export interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
---

<div data-reveal-group="220" class="flex px-[80px] justify-between items-center self-stretch">
  <!-- System -->
  <div data-reveal class="w-[1146px] shrink-0">
    <div class="text-[72px] leading-[1.3em] tracking-[-0.03em] font-medium text-black/40">{l(t.sections.system, locale)}</div>
    <a
      href="/work/wechat-store"
      class="block w-full mt-[56px] cursor-pointer transition-transform duration-[220ms] ease-[cubic-bezier(.2,0,.2,1)] hover:scale-[0.992] active:scale-[0.982]"
    >
      <div class="flex flex-col gap-[24px]">
        <div class="w-[1146px] h-[644px] overflow-hidden rounded-[56px]">
          <img src="/assets/system.png" alt={l(t.system.title, locale)}
            class="w-[1146px] h-[644px] object-cover" />
        </div>
        <ProjectInfoRow
          logo="/assets/logo_wechatshop.png"
          logoAlt="WeChat Shop logo"
          title={l(t.system.title, locale)}
          description={l(t.system.description, locale)}
          logoClass="rounded-[100px]"
        />
      </div>
    </a>
  </div>
  <!-- Research -->
  <div data-reveal class="w-[532px] shrink-0">
    <div class="text-[72px] leading-[1.3em] tracking-[-0.03em] font-medium text-black/40">{l(t.sections.research, locale)}</div>
    <a
      href="#"
      class="block w-full mt-[56px] cursor-pointer transition-transform duration-[220ms] ease-[cubic-bezier(.2,0,.2,1)] hover:scale-[0.992] active:scale-[0.982]"
    >
      <div class="flex flex-col gap-[24px]">
        <div class="w-[532px] h-[644px] overflow-hidden rounded-[56px]">
          <img src="/assets/research.png" alt={l(t.research.title, locale)}
            class="w-[532px] h-[644px] object-cover" />
        </div>
        <ProjectInfoRow
          logo="/assets/logo_midea.png"
          logoAlt="Midea logo"
          title={l(t.research.title, locale)}
          description={l(t.research.description, locale)}
          logoClass="rounded-[1000px] bg-[#0092D7]"
        />
      </div>
    </a>
  </div>
</div>
