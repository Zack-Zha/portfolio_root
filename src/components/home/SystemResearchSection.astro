---
// SystemResearchSection.astro — System + Research side-by-side
---

<div class="flex px-[80px] justify-between items-center self-stretch">
  <!-- System -->
  <div class="w-[1106px] min-[1920px]:w-[1140px] flex flex-col gap-[56px] shrink-0 transition-[width] duration-300">
    <div class="text-[72px] leading-[1.3em] tracking-[-0.03em] font-medium text-black/40">System.</div>
    <div class="flex flex-col gap-[20px] h-[690px]">
      <img src="/assets/system.png" alt="WeChat Store B-end Design System - WeChat"
        class="w-full h-[644px] object-cover rounded-[16px]" />
      <div class="text-[20px] leading-[1.3em] text-black/40">
        <span class="text-black">WeChat Store B-end Design System</span> - WeChat
      </div>
    </div>
  </div>
  <!-- Research -->
  <div class="w-[532px] flex flex-col gap-[56px] shrink-0">
    <div class="text-[72px] leading-[1.3em] tracking-[-0.03em] font-medium text-black/40">Research.</div>
    <div class="flex flex-col gap-[20px] h-[690px]">
      <img src="/assets/research.png" alt="SUPER UX Measurement Model - Midea"
        class="w-full h-[644px] object-cover rounded-[16px]" />
      <div class="text-[20px] leading-[1.3em] text-black/40">
        <span class="text-black">SUPER UX Measurement Model</span> - Midea
      </div>
    </div>
  </div>
</div>
