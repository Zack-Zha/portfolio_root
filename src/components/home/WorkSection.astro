---
import ProjectCard from './ProjectCard.astro';
import { projects } from '@/data/projects';
---

<div id="work" class="flex flex-col gap-[56px] scroll-mt-[120px]">
  <div class="flex items-center gap-[10px] px-[80px]">
    <div data-reveal class="text-[72px] leading-[1.3em] tracking-[-0.03em] font-medium text-black/40">Product.</div>
  </div>
  <div data-reveal-group="220" class="self-stretch px-20 inline-flex justify-between items-center">
    {projects.map((p) => (
      <ProjectCard
        title={p.title}
        href={p.href}
        image={p.image}
        alt={p.alt}
        cardId={p.id}
      />
    ))}
  </div>
</div>
