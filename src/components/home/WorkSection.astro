---
import ProjectCard from './ProjectCard.astro';
import { projects } from '@/data/projects';
import { t, l } from '@/i18n/home';
import type { Locale } from '@/i18n/home';

export interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
---

<div id="work" class="flex flex-col gap-[56px] scroll-mt-[120px]">
  <div class="flex items-center gap-[10px] px-[80px]">
    <div data-reveal class="text-[72px] leading-[1.3em] tracking-[-0.03em] font-medium text-black/40">{l(t.sections.product, locale)}</div>
  </div>
  <div class="self-stretch px-20 inline-flex justify-between items-center">
    {projects.map((p, index) => (
      <ProjectCard
        title={p.title[locale]}
        href={p.href}
        image={p.image}
        alt={p.alt[locale]}
        cardId={p.id}
        revealDelay={index * 220}
      />
    ))}
  </div>
</div>
