---
import ContactButtons from './ContactButtons.astro';
---

<div class="relative flex flex-col">
  <div class="relative z-[1] flex justify-between items-end gap-[316px] px-[80px] mt-[174px] flex-nowrap">
    <!-- Left: Name + Tagline -->
    <div class="flex flex-col gap-0 grow hero-char-reveal-root">
      <!-- "Hey, I'm" + Avatar + "Zack." -->
      <div id="introHover" class="w-[640px] flex items-end gap-[16px] group">
        <div class="text-[72px] leading-[1.3em] tracking-[-0.03em] font-medium text-black/40" aria-label="Hey, I'm">
          <span class="hero-char-word"><span class="hero-char" aria-hidden="true">H</span><span class="hero-char" aria-hidden="true">e</span><span class="hero-char" aria-hidden="true">y</span><span class="hero-char" aria-hidden="true">,</span></span>
          <span class="hero-char-word"><span class="hero-char" aria-hidden="true">I</span><span class="hero-char" aria-hidden="true">&rsquo;</span><span class="hero-char" aria-hidden="true">m</span></span>
        </div>
        <!-- Avatar swap on hover -->
        <div class="hero-avatar-unit w-[96px] h-[96px] shrink-0 flex items-center justify-center relative">
          <img src="/assets/avatar2.png" alt="Avatar"
            class="absolute inset-0 w-full h-full object-cover rotate-0 scale-0 transition-transform duration-[200ms] ease-[cubic-bezier(.4,0,.2,1)] group-hover:duration-[800ms] group-hover:[transition-timing-function:cubic-bezier(.34,1.56,.64,1)] [will-change:transform] group-hover:scale-100" />
          <img src="/assets/avatar.png" alt="Avatar"
            class="absolute inset-0 w-full h-full object-cover rotate-[15deg] scale-100 transition-transform duration-[800ms] ease-[cubic-bezier(.34,1.56,.64,1)] group-hover:duration-[200ms] group-hover:[transition-timing-function:cubic-bezier(.4,0,.2,1)] [will-change:transform] group-hover:scale-0 group-hover:rotate-0" />
        </div>
        <!-- "Zack." with glow -->
        <div id="zackTitle"
          class="group relative text-[72px] leading-[1.3em] tracking-[-0.03em] font-medium text-black/90 origin-left inline-block [will-change:transform]">
          <span class="relative z-0 hero-char-word" aria-label="Zack.">
            <span class="hero-char" aria-hidden="true">Z</span><span class="hero-char" aria-hidden="true">a</span><span class="hero-char" aria-hidden="true">c</span><span class="hero-char" aria-hidden="true">k</span><span class="hero-char" aria-hidden="true">.</span>
          </span>
          <span aria-hidden="true"
            class="absolute inset-0 z-20 pointer-events-none text-transparent bg-clip-text [-webkit-background-clip:text] [will-change:background-position] bg-[radial-gradient(circle_at_center,rgba(255,255,255,.55),rgba(255,255,255,0)_60%)] [background-size:180%_180%] [background-position:0%_50%] opacity-0 transition-opacity duration-[500ms] ease-[cubic-bezier(.4,0,.2,1)] group-hover:opacity-60 animate-[glowMove_10000ms_ease-in-out_infinite]"
          >Zack.</span>
        </div>
      </div>

      <!-- "I design for Media Ecology. Grounding Philosophy. Crafting Systems." -->
      <div class="text-[72px] leading-[1.3em] tracking-[-0.03em] font-medium text-black/40" aria-label="I design for Media Ecology. Grounding Philosophy. Crafting Systems.">
        <span class="hero-char-word"><span class="hero-char" aria-hidden="true">I</span></span>
        <span class="hero-char-word"><span class="hero-char" aria-hidden="true">d</span><span class="hero-char" aria-hidden="true">e</span><span class="hero-char" aria-hidden="true">s</span><span class="hero-char" aria-hidden="true">i</span><span class="hero-char" aria-hidden="true">g</span><span class="hero-char" aria-hidden="true">n</span></span>
        <span class="hero-char-word"><span class="hero-char" aria-hidden="true">f</span><span class="hero-char" aria-hidden="true">o</span><span class="hero-char" aria-hidden="true">r</span></span>
        {' '}
        <!-- Media Ecology -->
        <span id="mediaEcologyGroup" class="relative inline-block text-black/90 group">
          <span class="relative inline-block align-middle">
            <span class="relative z-0 hero-char-word" aria-label="Media Ecology.">
              <span class="hero-char" aria-hidden="true">M</span><span class="hero-char" aria-hidden="true">e</span><span class="hero-char" aria-hidden="true">d</span><span class="hero-char" aria-hidden="true">i</span><span class="hero-char" aria-hidden="true">a</span>
              <span class="hero-char" aria-hidden="true">&nbsp;</span>
              <span class="hero-char" aria-hidden="true">E</span><span class="hero-char" aria-hidden="true">c</span><span class="hero-char" aria-hidden="true">o</span><span class="hero-char" aria-hidden="true">l</span><span class="hero-char" aria-hidden="true">o</span><span class="hero-char" aria-hidden="true">g</span><span class="hero-char" aria-hidden="true">y</span><span class="hero-char" aria-hidden="true">.</span>
            </span>
            <span aria-hidden="true"
              class="absolute inset-0 z-20 pointer-events-none text-transparent bg-clip-text [-webkit-background-clip:text] [will-change:background-position] bg-[radial-gradient(circle_at_center,rgba(255,255,255,.55),rgba(255,255,255,0)_60%)] [background-size:180%_180%] [background-position:0%_50%] opacity-0 transition-opacity duration-[500ms] ease-[cubic-bezier(.4,0,.2,1)] group-hover:opacity-60 animate-[glowMove_10000ms_ease-in-out_infinite]"
            >Media Ecology.</span>
          </span>
          <span class="pointer-events-none absolute -inset-[32px] z-10">
            <img src="/assets/mc.png" alt=""
              class="absolute top-[-28px] left-[-36px] w-[52px] h-[52px] rounded-full object-cover opacity-0 transition-opacity duration-[800ms] ease-[cubic-bezier(.4,0,.2,1)] group-hover:opacity-100 animate-[bubbleA_14000ms_ease-in-out_infinite] [animation-delay:0ms]" />
            <img src="/assets/mon.png" alt=""
              class="absolute top-[-36px] right-[-44px] w-[44px] h-[44px] rounded-full object-cover opacity-0 transition-opacity duration-[800ms] ease-[cubic-bezier(.4,0,.2,1)] group-hover:opacity-100 animate-[bubbleB_16000ms_ease-in-out_infinite] [animation-delay:600ms]" />
            <img src="/assets/post.png" alt=""
              class="absolute bottom-[-30px] left-[50%] -translate-x-1/2 w-[36px] h-[36px] rounded-full object-cover opacity-0 transition-opacity duration-[800ms] ease-[cubic-bezier(.4,0,.2,1)] group-hover:opacity-100 animate-[bubbleC_18000ms_ease-in-out_infinite] [animation-delay:1200ms]" />
          </span>
        </span>
        {' '}
        <span class="hero-char-word"><span class="hero-char" aria-hidden="true">G</span><span class="hero-char" aria-hidden="true">r</span><span class="hero-char" aria-hidden="true">o</span><span class="hero-char" aria-hidden="true">u</span><span class="hero-char" aria-hidden="true">n</span><span class="hero-char" aria-hidden="true">d</span><span class="hero-char" aria-hidden="true">i</span><span class="hero-char" aria-hidden="true">n</span><span class="hero-char" aria-hidden="true">g</span></span>
        {' '}
        <!-- Philosophy -->
        <span class="relative inline-block text-black/90 group align-middle">
          <span class="relative z-0 hero-char-word" aria-label="Philosophy.">
            <span class="hero-char" aria-hidden="true">P</span><span class="hero-char" aria-hidden="true">h</span><span class="hero-char" aria-hidden="true">i</span><span class="hero-char" aria-hidden="true">l</span><span class="hero-char" aria-hidden="true">o</span><span class="hero-char" aria-hidden="true">s</span><span class="hero-char" aria-hidden="true">o</span><span class="hero-char" aria-hidden="true">p</span><span class="hero-char" aria-hidden="true">h</span><span class="hero-char" aria-hidden="true">y</span><span class="hero-char" aria-hidden="true">.</span>
          </span>
          <span aria-hidden="true"
            class="absolute inset-0 z-20 pointer-events-none text-transparent bg-clip-text [-webkit-background-clip:text] [will-change:background-position] bg-[radial-gradient(circle_at_center,rgba(255,255,255,.55),rgba(255,255,255,0)_60%)] [background-size:180%_180%] [background-position:0%_50%] opacity-0 transition-opacity duration-[500ms] ease-[cubic-bezier(.4,0,.2,1)] group-hover:opacity-60 animate-[glowMove_10000ms_ease-in-out_infinite]"
          >Philosophy.</span>
          <span class="pointer-events-none absolute -inset-[28px] z-10">
            <img src="/assets/nc.png" alt=""
              class="absolute top-[-22px] left-[-30px] w-[48px] h-[48px] rounded-full object-cover opacity-0 transition-opacity duration-[800ms] ease-[cubic-bezier(.4,0,.2,1)] group-hover:opacity-100 animate-[bubbleP1_15000ms_ease-in-out_infinite] [animation-delay:0ms]" />
            <img src="/assets/fc.png" alt=""
              class="absolute bottom-[-26px] right-[-36px] w-[40px] h-[40px] rounded-full object-cover opacity-0 transition-opacity duration-[800ms] ease-[cubic-bezier(.4,0,.2,1)] group-hover:opacity-100 animate-[bubbleP2_17000ms_ease-in-out_infinite] [animation-delay:800ms]" />
            <img src="/assets/alex.png" alt=""
              class="absolute top-[-10px] left-[58%] w-[34px] h-[34px] rounded-full object-cover opacity-0 transition-opacity duration-[800ms] ease-[cubic-bezier(.4,0,.2,1)] group-hover:opacity-100 animate-[bubbleP3_19000ms_ease-in-out_infinite] [animation-delay:1400ms]" />
          </span>
        </span>
        {' '}
        <span class="hero-char-word"><span class="hero-char" aria-hidden="true">C</span><span class="hero-char" aria-hidden="true">r</span><span class="hero-char" aria-hidden="true">a</span><span class="hero-char" aria-hidden="true">f</span><span class="hero-char" aria-hidden="true">t</span><span class="hero-char" aria-hidden="true">i</span><span class="hero-char" aria-hidden="true">n</span><span class="hero-char" aria-hidden="true">g</span></span>
        {' '}
        <!-- Systems -->
        <span class="relative inline-block text-black/90 group align-middle">
          <span class="relative z-0 hero-char-word" aria-label="Systems.">
            <span class="hero-char" aria-hidden="true">S</span><span class="hero-char" aria-hidden="true">y</span><span class="hero-char" aria-hidden="true">s</span><span class="hero-char" aria-hidden="true">t</span><span class="hero-char" aria-hidden="true">e</span><span class="hero-char" aria-hidden="true">m</span><span class="hero-char" aria-hidden="true">s</span><span class="hero-char" aria-hidden="true">.</span>
          </span>
          <span aria-hidden="true"
            class="absolute inset-0 z-20 pointer-events-none text-transparent bg-clip-text [-webkit-background-clip:text] [will-change:background-position] bg-[radial-gradient(circle_at_center,rgba(255,255,255,.55),rgba(255,255,255,0)_60%)] [background-size:180%_180%] [background-position:0%_50%] opacity-0 transition-opacity duration-[500ms] ease-[cubic-bezier(.4,0,.2,1)] group-hover:opacity-60 animate-[glowMove_10000ms_ease-in-out_infinite]"
          >Systems.</span>
          <span class="pointer-events-none absolute -inset-[26px] z-10">
            <img src="/assets/lm.png" alt="" onerror="this.style.display='none'"
              class="absolute top-[-18px] left-[-28px] w-[46px] h-[46px] rounded-full object-cover opacity-0 transition-opacity duration-[800ms] ease-[cubic-bezier(.4,0,.2,1)] group-hover:opacity-100 animate-[bubbleS1_16000ms_ease-in-out_infinite] [animation-delay:0ms]" />
            <img src="/assets/vc.png" alt="" onerror="this.style.display='none'"
              class="absolute top-[-12px] right-[-34px] w-[38px] h-[38px] rounded-full object-cover opacity-0 transition-opacity duration-[800ms] ease-[cubic-bezier(.4,0,.2,1)] group-hover:opacity-100 animate-[bubbleS2_18000ms_ease-in-out_infinite] [animation-delay:700ms]" />
            <img src="/assets/nw.png" alt="" onerror="this.style.display='none'"
              class="absolute bottom-[-24px] left-[62%] w-[32px] h-[32px] rounded-full object-cover opacity-0 transition-opacity duration-[800ms] ease-[cubic-bezier(.4,0,.2,1)] group-hover:opacity-100 animate-[bubbleS3_20000ms_ease-in-out_infinite] [animation-delay:1300ms]" />
          </span>
        </span>
      </div>
    </div>

    <!-- Right: Contact Buttons -->
    <ContactButtons />
  </div>

  <!-- Info Bar -->
  <div data-reveal data-reveal-delay="1850" class="relative z-[1] self-stretch px-20 inline-flex justify-between items-center mt-[96px]">
    <div class="flex-1 inline-flex flex-col justify-start items-start gap-3">
      <div class="self-stretch justify-start text-black/90 text-xl font-normal font-['Geist']">
        Current: Tencent - WeChat Design Team
      </div>
      <div class="self-stretch justify-start">
        <span class="text-black/90 text-xl font-normal font-['Geist']">Role: Product Experience Designer</span>
        <span class="text-black/40 text-xl font-normal font-['Geist']"> (Intern)</span>
      </div>
    </div>
    <div class="flex-1 inline-flex flex-col justify-start items-start gap-3">
      <div class="self-stretch justify-start text-black/90 text-xl font-normal font-['Geist']">
        Phone (WeChat): +86 19120330185
      </div>
      <div class="self-stretch justify-start text-black/90 text-xl font-normal font-['Geist']">
        E-mail: ChengkeZha@gmail.com
      </div>
    </div>
  </div>
</div>

<style>
  /* ===== Desktop character reveal (769px+) ===== */
  @media (min-width: 769px) {
    .hero-char-reveal-root .hero-char {
      opacity: 0;
      transform: translateY(16px);
      filter: blur(3px);
      transition:
        opacity 1000ms cubic-bezier(0.22, 1, 0.36, 1),
        transform 1000ms cubic-bezier(0.22, 1, 0.36, 1),
        filter 1000ms cubic-bezier(0.22, 1, 0.36, 1);
      transition-delay: calc(var(--hci, 0) * 26ms);
    }

    .hero-char-reveal-root.is-active .hero-char {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }

    .hero-char-reveal-root .hero-avatar-unit {
      opacity: 0;
      transform: translateY(20px) scale(0.92);
      filter: blur(4px);
      transition:
        opacity 1150ms cubic-bezier(0.22, 1, 0.36, 1),
        transform 1150ms cubic-bezier(0.22, 1, 0.36, 1),
        filter 1150ms cubic-bezier(0.22, 1, 0.36, 1);
      transition-delay: calc(var(--hci, 0) * 26ms);
    }

    .hero-char-reveal-root.is-active .hero-avatar-unit {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }

    /* Prevent word breaks between characters */
    .hero-char-word {
      display: inline-block;
      white-space: nowrap;
    }

    @media (prefers-reduced-motion: reduce) {
      .hero-char-reveal-root .hero-char,
      .hero-char-reveal-root .hero-avatar-unit {
        opacity: 1;
        transform: none;
        filter: none;
        transition: none;
        transition-delay: 0ms;
      }
    }
  }
</style>

<script>
  (function () {
    if (window.matchMedia('(max-width: 768px)').matches) return;
    const root = document.querySelector('.hero-char-reveal-root');
    if (!root) return;
    // Assign sequential indices to all char + avatar units for staggered reveal
    root.querySelectorAll('.hero-char, .hero-avatar-unit').forEach(function (el, i) {
      el.style.setProperty('--hci', String(i));
    });
    requestAnimationFrame(function () {
      root.classList.add('is-active');
    });
  })();
</script>

<!-- Zack Title Swing Animation Script -->
<script>
  const z = document.getElementById('zackTitle');
  const g = document.getElementById('introHover');
  if (z && g) {
    let swingAnim = null;
    let introAnim = null;
    let returnAnim = null;
    const startSwing = () => {
      if (returnAnim) { returnAnim.cancel(); returnAnim = null; }
      if (swingAnim) { swingAnim.cancel(); swingAnim = null; }
      if (introAnim) { introAnim.cancel(); introAnim = null; }
      const cur = getAngle();
      z.style.transform = `rotate(${cur}deg)`;
      const normalize = cur !== 0 ? z.animate(
        [{ transform: `rotate(${cur}deg)` }, { transform: 'rotate(0deg)' }],
        { duration: 120, easing: 'cubic-bezier(.4,0,.2,1)', fill: 'forwards' }
      ) : null;
      const afterNormalize = () => {
        z.style.transform = 'rotate(0deg)';
        introAnim = z.animate(
          [{ transform: 'rotate(0deg)' }, { transform: 'rotate(5deg)' }],
          { duration: 400, easing: 'cubic-bezier(.2,1,.3,1)', fill: 'forwards' }
        );
        introAnim.onfinish = () => {
          z.style.transform = 'rotate(5deg)';
          introAnim = null;
          swingAnim = z.animate(
            [{ transform: 'rotate(5deg)' }, { transform: 'rotate(-5deg)' }],
            { duration: 1200, iterations: Infinity, direction: 'alternate', easing: 'cubic-bezier(.4,0,.2,1)' }
          );
        };
      };
      if (normalize) {
        normalize.onfinish = afterNormalize;
      } else {
        afterNormalize();
      }
    };
    const getAngle = () => {
      const tf = getComputedStyle(z).transform;
      if (!tf || tf === 'none') return 0;
      const m = tf.match(/matrix\(([-\d.,\s]+)\)/);
      if (!m) return 0;
      const nums = m[1].split(',').map(s => parseFloat(s.trim()));
      const a = nums[0], b = nums[1];
      return Math.atan2(b, a) * (180 / Math.PI);
    };
    g.addEventListener('mouseenter', () => {
      startSwing();
    });
    g.addEventListener('mouseleave', () => {
      const angle = getAngle();
      if (introAnim) { introAnim.cancel(); introAnim = null; }
      if (swingAnim) { swingAnim.cancel(); swingAnim = null; }
      z.style.transform = `rotate(${angle}deg)`;
      returnAnim = z.animate(
        [{ transform: `rotate(${angle}deg)` }, { transform: 'rotate(0deg)' }],
        { duration: 400, easing: 'cubic-bezier(.4,0,.2,1)', fill: 'forwards' }
      );
      returnAnim.onfinish = () => {
        z.style.transform = 'rotate(0deg)';
        returnAnim = null;
      };
    });
  }
</script>
