---
import { explorations } from '@/data/explorations';
import ProjectInfoRow from '@/components/common/ProjectInfoRow.astro';
---

<div class="flex flex-col gap-[56px] px-[80px] mt-[40px]">
  <div data-reveal class="text-[76px] leading-[1.3em] tracking-[-0.03em] font-medium text-black/40">Exploration.</div>
  <div data-reveal-group="220" class="self-stretch inline-flex justify-start items-start gap-[25px]">
    {explorations.map((item) => (
      <div data-reveal class="w-[570px] inline-flex flex-col justify-center items-start gap-[24px]">
        <img src={item.image} alt={item.alt} class="w-[570px] h-[640px] object-cover" />
        <ProjectInfoRow
          logo={item.logo}
          logoAlt={item.logoAlt}
          title={item.title}
          description={item.description}
        />
      </div>
    ))}
  </div>
</div>
