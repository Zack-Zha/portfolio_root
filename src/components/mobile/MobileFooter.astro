---
// MobileFooter.astro — Mobile footer (Figma)
---

<footer data-reveal data-reveal-duration="900" data-reveal-y="28" data-reveal-blur="4" class="pt-[96px] pb-[80px] flex flex-col justify-center items-center gap-[16px] bg-[#F0F0F0]">
  <div class="flex flex-col justify-center items-center gap-[10px]">
    <img src="/assets/avatar2.png" alt="Avatar" class="w-[112px] h-[112px]" />
    <div class="text-black/90 text-[28px] font-geist font-normal">Ready to build something that shapes us? Let&rsquo;s talk.</div>
  </div>
  <div class="text-black/50 text-[28px] font-geist font-normal">Chengke Zha &copy; <span id="mobile-copyright-year">2025</span></div>
</footer>

<script>
  document.getElementById('mobile-copyright-year').textContent = new Date().getFullYear();
</script>
