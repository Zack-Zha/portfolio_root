---
import { mobileExplorations } from '@/data/mobileExplorations';
import { t, l } from '@/i18n/home';
import type { Locale } from '@/i18n/home';

export interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
---

<div class="flex flex-col">
  <div class="px-[32px] py-[24px]">
    <div data-reveal class="text-black/40 text-[56px] font-geist font-medium leading-[1.3]">{l(t.sections.exploration, locale)}</div>
  </div>
  <div class="px-[32px] py-[32px]">
    <div data-reveal-group="260" class="grid grid-cols-2 gap-x-[24px] gap-y-[48px]">
      {mobileExplorations.map((item) => (
        <div data-reveal class="flex flex-col gap-[24px]">
          {item.image ? (
            <img src={item.image} alt={item.alt[locale]} class="self-stretch h-[386px] rounded-[32px] object-cover" />
          ) : (
            <div class="self-stretch h-[386px] rounded-[32px] bg-[rgba(0,0,0,0.03)] border border-[rgba(0,0,0,0.05)]" aria-label={item.alt[locale] + ' placeholder'}></div>
          )}
          <div class="flex flex-col gap-[16px]">
            <div class="text-black/80 text-[32px] font-geist font-medium capitalize leading-[1.3]">{item.title[locale]}</div>
            <div class="text-black/40 text-[28px] font-geist leading-[1.3]">{item.description[locale]}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
