---
import { explorations } from '@/data/explorations';
---

<div class="px-[32px] py-[24px] flex flex-col gap-[24px]">
  <div data-reveal data-reveal-duration="900" data-reveal-y="28" data-reveal-blur="4" class="text-black/40 text-[56px] font-geist font-medium leading-[1.3]">Exploration.</div>
  <div data-reveal-group="160" class="grid grid-cols-2 gap-[24px]">
    {explorations.map((item) => (
      <div data-reveal class="flex flex-col gap-[16px]">
        <img src={item.image} alt={item.alt} class="w-full h-[386px] object-cover rounded-[32px]" />
        <div class="flex items-start gap-[16px]">
          <img src={item.logo} alt={item.logoAlt} class="w-[72px] h-[72px] object-contain shrink-0" />
          <div class="flex-1 flex flex-col gap-[4px]">
            <div class="text-black/80 text-[24px] font-geist font-medium capitalize leading-[1.3]">{item.title}</div>
            <div class="text-black/40 text-[20px] font-geist leading-[1.3]">{item.description}</div>
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
