---
import { mobileExplorations } from '@/data/mobileExplorations';
---

<div class="flex flex-col">
  <div class="px-[32px] py-[24px]">
    <div data-reveal class="text-black/40 text-[56px] font-geist font-medium leading-[1.3]">Exploration.</div>
  </div>
  <div class="px-[32px] py-[32px]">
    <div data-reveal-group="260" class="grid grid-cols-2 gap-x-[24px] gap-y-[48px]">
      {mobileExplorations.map((item) => (
        <div data-reveal class="flex flex-col gap-[24px]">
          {item.image ? (
            <img src={item.image} alt={item.alt} class="self-stretch h-[386px] rounded-[32px] object-cover" />
          ) : (
            <div class="self-stretch h-[386px] rounded-[32px] bg-[rgba(0,0,0,0.03)] border border-[rgba(0,0,0,0.05)]" aria-label={item.alt + ' placeholder'}></div>
          )}
          <div class="flex flex-col gap-[16px]">
            <div class="text-black/80 text-[32px] font-geist font-medium capitalize leading-[1.3]">{item.title}</div>
            <div class="text-black/40 text-[28px] font-geist leading-[1.3]">{item.description}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
