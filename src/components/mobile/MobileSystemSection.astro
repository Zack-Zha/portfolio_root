---
// MobileSystemSection.astro — Figma mobile System section
import { t, l } from '@/i18n/home';
import type { Locale } from '@/i18n/home';

export interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
---

<div class="flex flex-col">
  <div class="px-[32px] py-[24px]">
    <div data-reveal class="text-black/40 text-[56px] font-geist font-medium leading-[1.3]">{l(t.sections.system, locale)}</div>
  </div>
  <div data-reveal-group="260" class="px-[32px] py-[32px] flex flex-col gap-[24px]">
    <div data-reveal>
      <img src="/assets/mobile-system.png" alt={l(t.system.title, locale)}
        class="w-[704px] h-[400px] object-cover rounded-[32px]" />
    </div>
    <div data-reveal class="flex flex-col gap-[16px]">
      <div class="text-black/80 text-[32px] font-geist font-medium capitalize leading-[1.3]">{l(t.system.title, locale)}</div>
      <div class="text-black/40 text-[28px] font-geist leading-[1.3]">{l(t.system.description, locale)}</div>
    </div>
  </div>
</div>
