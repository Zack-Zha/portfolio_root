---
// MobileNavbar.astro — Status bar + navbar with glass icon buttons
---

<div class="mobile-navbar-wrapper">
  <!-- iOS-style status bar -->
  <div class="h-[92px] relative bg-transparent">
    <div class="absolute left-[53px] top-[26px] text-[33px] font-semibold text-black/90 font-['SF_Pro_Text',system-ui]">9:41</div>
    <!-- Battery icon -->
    <div class="absolute right-[53px] top-[33px] flex items-center gap-[12px]">
      <!-- Cellular -->
      <svg width="36" height="24" viewBox="0 0 36 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M19.69 5.91a1.97 1.97 0 0 1 1.97-1.97h1.97a1.97 1.97 0 0 1 1.97 1.97v15.75a1.97 1.97 0 0 1-1.97 1.97h-1.97a1.97 1.97 0 0 1-1.97-1.97V5.9Z" fill="currentColor" class="text-black/90"/>
        <path d="M29.54 1.97a1.97 1.97 0 0 1 1.97-1.97h1.97a1.97 1.97 0 0 1 1.97 1.97v19.69a1.97 1.97 0 0 1-1.97 1.97h-1.97a1.97 1.97 0 0 1-1.97-1.97V1.97Z" fill="currentColor" class="text-black/90"/>
        <path d="M9.85 12.8a1.97 1.97 0 0 1 1.97-1.97h1.97a1.97 1.97 0 0 1 1.96 1.97v8.86a1.97 1.97 0 0 1-1.96 1.97h-1.97a1.97 1.97 0 0 1-1.97-1.97V12.8Z" fill="currentColor" class="text-black/90"/>
        <path d="M0 17.72a1.97 1.97 0 0 1 1.97-1.97h1.97a1.97 1.97 0 0 1 1.97 1.97v3.94a1.97 1.97 0 0 1-1.97 1.97H1.97A1.97 1.97 0 0 1 0 21.66V17.72Z" fill="currentColor" class="text-black/90"/>
      </svg>
      <!-- Wi-Fi -->
      <svg width="34" height="24" viewBox="0 0 34 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12.04 17.56a6.88 6.88 0 0 1 9.69 0 .6.6 0 0 1 .02 1.02l-4.38 4.51a.58.58 0 0 1-.48.19.58.58 0 0 1-.49-.19l-4.38-4.51a.6.6 0 0 1 .02-1.02ZM6.12 12.17a15.23 15.23 0 0 1 21.38 0 .58.58 0 0 1 .01 1.03l-2.53 2.61a.55.55 0 0 1-.95-.01 9.29 9.29 0 0 0-14.44 0 .56.56 0 0 1-.95 0l-2.53-2.6a.58.58 0 0 1 .01-1.03ZM.21 6.78a25.64 25.64 0 0 1 33.06 0 .57.57 0 0 1 0 1.02l-2.53 2.61a.56.56 0 0 1-.95 0 17.8 17.8 0 0 0-26.1 0 .56.56 0 0 1-.95 0L.21 7.8a.57.57 0 0 1 0-1.02Z" fill="currentColor" class="text-black/90"/>
      </svg>
      <!-- Battery -->
      <svg width="55" height="27" viewBox="0 0 55 27" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path opacity=".35" d="M7.88.98h33.47a6.9 6.9 0 0 1 6.9 6.9v9.84a6.9 6.9 0 0 1-6.9 6.9H7.88a6.9 6.9 0 0 1-6.9-6.9V7.88A6.9 6.9 0 0 1 7.88.98Z" stroke="currentColor" class="text-black/90" stroke-width="1.97"/>
        <path opacity=".4" d="M51.2 9.85v8.31a2.8 2.8 0 0 0 2.76-4.16 2.8 2.8 0 0 0-2.76-4.15" fill="currentColor" class="text-black/90"/>
        <path d="M3.94 7.88a3.94 3.94 0 0 1 3.94-3.94h33.48a3.94 3.94 0 0 1 3.93 3.94v9.84a3.94 3.94 0 0 1-3.93 3.94H7.88a3.94 3.94 0 0 1-3.94-3.94V7.88Z" fill="currentColor" class="text-black/90"/>
      </svg>
    </div>
  </div>

  <!-- Navbar container -->
  <div class="px-[32px] py-[24px] bg-[rgba(237,237,237,0.5)] backdrop-blur-[50px] flex justify-between items-center">
    <!-- Left icon button (layered glass) -->
    <button class="mobile-nav-icon relative w-[96px] h-[96px] rounded-[120px] overflow-hidden">
      <span class="absolute inset-0 z-0 rounded-[120px] bg-white/20 backdrop-blur-[28px]"></span>
      <span class="relative z-10 flex w-full h-full items-center justify-center rounded-[120px] bg-[linear-gradient(315deg,rgba(0,0,0,0.01)_0%,rgba(0,0,0,0.05)_100%)] shadow-[inset_0px_2px_2px_rgba(0,0,0,0.10),inset_0px_-2px_4px_rgba(255,255,255,1),0px_8px_40px_rgba(0,0,0,0.08)]">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="4" y="6" width="16" height="12" rx="2" stroke="currentColor" class="text-black/80" stroke-width="1.5"/>
          <path d="M4 7l8 6 8-6" stroke="currentColor" class="text-black/80" stroke-width="1.5"/>
        </svg>
      </span>
    </button>

    <div class="text-black text-[32px] font-geist font-medium">Zha Chengke</div>

    <!-- Right icon button (layered glass) -->
    <button class="mobile-nav-icon relative w-[96px] h-[96px] rounded-[120px] overflow-hidden">
      <span class="absolute inset-0 z-0 rounded-[120px] bg-white/20 backdrop-blur-[28px]"></span>
      <span class="relative z-10 flex w-full h-full items-center justify-center rounded-[120px] bg-[linear-gradient(315deg,rgba(0,0,0,0.01)_0%,rgba(0,0,0,0.05)_100%)] shadow-[inset_0px_2px_2px_rgba(0,0,0,0.10),inset_0px_-2px_4px_rgba(255,255,255,1),0px_8px_40px_rgba(0,0,0,0.08)]">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M4 6h16M4 12h16M4 18h12" stroke="currentColor" class="text-black/80" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </span>
    </button>
  </div>
</div>
