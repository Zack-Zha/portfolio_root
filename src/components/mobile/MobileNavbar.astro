---
// MobileNavbar.astro — Fixed navbar with glass icon buttons
import { t, l } from '@/i18n/home';
import type { Locale } from '@/i18n/home';

export interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const name = l(t.mobileNav.name, locale);
---

<div class="mobile-navbar-wrapper w-full">
  <!-- Navbar container -->
  <div class="px-[32px] py-[24px] flex justify-between items-center">
    <!-- Left icon button: bottom glass layer + top surface layer -->
    <button class="relative w-[96px] h-[96px] rounded-[120px]">
      <span class="absolute inset-0 z-0 rounded-[120px] bg-white/20 backdrop-blur-[12px]"></span>
      <span class="relative z-10 flex w-full h-full items-center justify-center rounded-[120px] bg-[linear-gradient(315deg,rgba(0,0,0,0.01)_0%,rgba(0,0,0,0.05)_100%)] shadow-[inset_0px_2px_2px_rgba(0,0,0,0.10),inset_0px_-2px_4px_rgba(255,255,255,1),0px_8px_40px_rgba(0,0,0,0.08)]">
        <img src="/assets/mobile-house.svg" alt="" width="42" height="37" />
      </span>
    </button>

    <div id="mobile-nav-name" class="text-black text-[32px] font-geist font-medium">{name}</div>

    <!-- Right icon button: bottom glass layer + top surface layer -->
    <button class="relative w-[96px] h-[96px] rounded-[120px]">
      <span class="absolute inset-0 z-0 rounded-[120px] bg-white/20 backdrop-blur-[12px]"></span>
      <span class="relative z-10 flex w-full h-full items-center justify-center rounded-[120px] bg-[linear-gradient(315deg,rgba(0,0,0,0.01)_0%,rgba(0,0,0,0.05)_100%)] shadow-[inset_0px_2px_2px_rgba(0,0,0,0.10),inset_0px_-2px_4px_rgba(255,255,255,1),0px_8px_40px_rgba(0,0,0,0.08)]">
        <img src="/assets/mobile-hamburger.svg" alt="" width="36" height="18" />
      </span>
    </button>
  </div>
</div>

<script>
  const name = document.getElementById('mobile-nav-name');
  if (name) {
    const FADE_DISTANCE = 60;
    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY || window.pageYOffset;
      const opacity = Math.max(0, 1 - scrollY / FADE_DISTANCE);
      name.style.opacity = String(opacity);
    }, { passive: true });
  }
</script>
