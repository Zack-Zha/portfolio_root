---
// MobileHero.astro — Mobile hero section (Figma)
---

<div class="w-full">
  <!-- Name + tagline -->
  <div class="px-[32px] py-[24px] flex flex-col items-start">
    <div class="inline-flex items-center gap-[8px]">
      <div class="text-black/40 text-[54px] font-geist font-medium">Hey, I&rsquo;m</div>
      <img src="/assets/avatar3.png" alt="Avatar" class="w-[72px] h-[72px]" />
      <div class="text-black text-[54px] font-geist font-medium">Zack.</div>
    </div>
    <div class="w-full text-[54px] font-geist font-medium">
      <span class="text-black/40">I design for </span>
      <span class="text-black/90">Media Ecology. </span>
      <span class="text-black/40">Grounding </span>
      <span class="text-black/90">Philosophy. </span>
      <span class="text-black/40">Crafting </span>
      <span class="text-black/90">Systems.</span>
    </div>
  </div>

  <!-- Info cards + Contact -->
  <div class="px-[32px] py-[24px] flex flex-col items-start gap-[16px]">
    <!-- Info cards row -->
    <div class="self-stretch flex items-center gap-[16px]">
      <!-- Current card -->
      <div class="flex-1 p-[32px] bg-[rgba(0,0,0,0.02)] rounded-[32px] outline outline-1 outline-[rgba(0,0,0,0.05)] flex flex-col items-start gap-[32px]" style="outline-offset: -1px;">
        <div class="self-stretch flex justify-between items-center">
          <div class="text-black/50 text-[28px] font-geist font-normal">Current</div>
          <img src="/assets/mobile-building.svg" alt="" class="w-[42px] h-[36px]" />
        </div>
        <div class="self-stretch text-black/90 text-[28px] font-geist font-normal">Tencent &mdash; WeChat Design Team</div>
      </div>

      <!-- Education card -->
      <div class="flex-1 p-[32px] bg-[rgba(0,0,0,0.02)] rounded-[32px] outline outline-1 outline-[rgba(0,0,0,0.05)] flex flex-col items-start gap-[32px]" style="outline-offset: -1px;">
        <div class="self-stretch flex justify-between items-center">
          <div class="text-black/50 text-[28px] font-geist font-normal">Education</div>
          <img src="/assets/mobile-education.svg" alt="" class="w-[40px] h-[36px]" />
        </div>
        <div class="self-stretch text-black/90 text-[28px] font-geist font-normal">M.Sc. in Interaction Design, PolyU</div>
      </div>
    </div>

    <!-- Contact card -->
    <div class="self-stretch p-[32px] bg-[rgba(0,0,0,0.02)] rounded-[32px] outline outline-1 outline-[rgba(0,0,0,0.05)] flex flex-col items-start gap-[32px]" style="outline-offset: -1px;">
      <!-- Phone row -->
      <div class="self-stretch flex justify-between items-center">
        <div class="flex items-center gap-[16px]">
          <img src="/assets/mobile-phone.svg" alt="" class="w-[34px] h-[34px]" />
          <div class="text-black/50 text-[28px] font-geist font-normal">Phone (WeChat)</div>
        </div>
        <div class="text-black/90 text-[28px] font-geist font-normal">+86 19120330185</div>
      </div>

      <!-- Divider -->
      <img src="/assets/mobile-divider.svg" alt="" class="self-stretch w-full h-[1px]" />

      <!-- Email row -->
      <div class="self-stretch flex justify-between items-center">
        <div class="flex items-center gap-[16px]">
          <img src="/assets/mobile-email.svg" alt="" class="w-[37px] h-[26px]" />
          <div class="text-black/50 text-[28px] font-geist font-normal">Email</div>
        </div>
        <div class="text-black/90 text-[28px] font-geist font-normal">2745940185@qq.com</div>
      </div>
    </div>
  </div>
</div>
