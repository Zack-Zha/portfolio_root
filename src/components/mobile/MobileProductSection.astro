---
import MobileProductCard from './MobileProductCard.astro';
import { projects } from '@/data/projects';
---

<div class="px-[32px] py-[24px] flex flex-col gap-[32px]">
  <div data-reveal data-reveal-duration="900" data-reveal-y="28" data-reveal-blur="4" class="text-black/40 text-[56px] font-geist font-medium leading-[1.3]">Product.</div>
  <div data-reveal-group="160" class="flex flex-col gap-[32px] items-center">
    {projects.map((p, index) => (
      <div data-reveal>
        <MobileProductCard
          title={p.title}
          href={p.href}
          image={p.image}
          alt={p.alt}
          cardId={p.id}
          revealDelay={index * 160}
        />
      </div>
    ))}
  </div>
</div>
