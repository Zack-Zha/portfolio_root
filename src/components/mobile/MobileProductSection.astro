---
import MobileProductCard from './MobileProductCard.astro';
import { projects } from '@/data/projects';
---

<div class="flex flex-col">
  <div class="px-[32px] py-[24px]">
    <div data-reveal data-reveal-duration="900" data-reveal-y="28" data-reveal-blur="4" class="text-black/40 text-[56px] font-geist font-medium leading-[1.3]">Product.</div>
  </div>
  <div class="self-stretch pt-[32px] pb-[48px] flex justify-center">
    <div data-reveal-group="160" class="flex flex-col items-center gap-[120px]">
      {projects.map((p, index) => (
        <MobileProductCard
          title={p.title}
          href={p.href}
          image={p.image}
          alt={p.alt}
          cardId={p.id}
          revealDelay={index * 160}
        />
      ))}
    </div>
  </div>
</div>
