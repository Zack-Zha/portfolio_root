---
import SiteLayout from '@/components/layout/SiteLayout.astro';
import Hero from '@/components/home/Hero.astro';
import WorkSection from '@/components/home/WorkSection.astro';
import SystemResearchSection from '@/components/home/SystemResearchSection.astro';
import ExplorationSection from '@/components/home/ExplorationSection.astro';
---

<SiteLayout title="Portfolio" showAmbient={true} isHome={true}>
  <Hero />
  <WorkSection />
  <SystemResearchSection />
  <ExplorationSection />
</SiteLayout>

<style is:global>
  /* ===== Reveal Animation System ===== */

  [data-reveal] {
    opacity: 0;
    transform: translateY(var(--reveal-y, 32px));
    filter: blur(var(--reveal-blur, 8px));
    transition:
      opacity var(--reveal-duration, 1150ms) var(--reveal-ease, cubic-bezier(0.22, 1, 0.36, 1)),
      transform var(--reveal-duration, 1150ms) var(--reveal-ease, cubic-bezier(0.22, 1, 0.36, 1)),
      filter var(--reveal-duration, 1150ms) var(--reveal-ease, cubic-bezier(0.22, 1, 0.36, 1));
    transition-delay: var(--reveal-delay, 0ms);
  }

  [data-reveal].is-revealed {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  /*
   * No-blur mode — for elements containing internal backdrop-filter / foreignObject.
   * blur(0px) still creates a compositor layer that contaminates backdrop-filter sampling.
   * Must use filter: none and exclude filter from the transition entirely.
   */
  [data-reveal][data-reveal-no-blur] {
    filter: none !important;
    transition:
      opacity var(--reveal-duration, 1150ms) var(--reveal-ease, cubic-bezier(0.22, 1, 0.36, 1)),
      transform var(--reveal-duration, 1150ms) var(--reveal-ease, cubic-bezier(0.22, 1, 0.36, 1));
    transition-delay: var(--reveal-delay, 0ms);
  }

  [data-reveal][data-reveal-no-blur].is-revealed {
    filter: none !important;
  }

  /*
   * Reset-transform mode — after animation completes, remove transform entirely.
   * translateY(0) still creates a compositor layer that can pollute backdrop-filter.
   * Use reveal-complete to switch to transform: none.
   */
  [data-reveal][data-reveal-reset-transform].reveal-complete {
    transform: none !important;
    filter: none !important;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      transform: translateY(0);
      filter: blur(0);
      transition-duration: 200ms;
    }
  }
</style>

<script>
  /**
   * Reveal animation system — IntersectionObserver with stagger support.
   *
   * Markup:
   *   <div data-reveal>Single element</div>
   *   <div data-reveal-group="220">
   *     <div data-reveal>Child 1</div>
   *     <div data-reveal>Child 2</div>
   *   </div>
   *
   * Per-element overrides:
   *   data-reveal-delay="440"       Override stagger delay (ms)
   *   data-reveal-duration="900"    Transition duration (ms)
   *   data-reveal-y="20"            TranslateY offset (px)
   *   data-reveal-blur="4"          Blur amount (px)
   *   data-reveal-no-blur           Disable blur (for elements with backdrop-filter)
   */
  const STAGGER_DEFAULT = 220;

  function applyReveal(el, delayMs) {
    if (el.dataset.revealDelay !== undefined) {
      delayMs = parseInt(el.dataset.revealDelay, 10);
    }

    const durationMs = el.dataset.revealDuration !== undefined
      ? parseInt(el.dataset.revealDuration, 10)
      : 1150;

    if (el.dataset.revealDuration !== undefined) {
      el.style.setProperty('--reveal-duration', durationMs + 'ms');
    }
    if (el.dataset.revealY !== undefined) {
      el.style.setProperty('--reveal-y', el.dataset.revealY + 'px');
    }
    if (el.dataset.revealBlur !== undefined) {
      el.style.setProperty('--reveal-blur', el.dataset.revealBlur + 'px');
    }
    el.style.setProperty('--reveal-delay', delayMs + 'ms');
    el.classList.add('is-revealed');

    // After animation finishes, clean up transform for reset-transform elements
    // so they don't retain a compositor layer that pollutes backdrop-filter
    if (el.hasAttribute('data-reveal-reset-transform')) {
      setTimeout(function () {
        el.classList.add('reveal-complete');
      }, delayMs + durationMs + 80);
    }
  }

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        const el = entry.target;

        const group = el.closest('[data-reveal-group]');
        if (group && !group.dataset.revealGroupProcessed) {
          group.dataset.revealGroupProcessed = '1';
          const staggerMs =
            parseInt(group.getAttribute('data-reveal-group') || '', 10) ||
            STAGGER_DEFAULT;
          const children = group.querySelectorAll(':scope > [data-reveal]');
          children.forEach((child, i) => applyReveal(child, i * staggerMs));
        } else if (!group) {
          applyReveal(el, 0);
        }

        observer.unobserve(el);
      }
    },
    { threshold: 0.12, rootMargin: '0px 0px -10% 0px' }
  );

  document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));
</script>
