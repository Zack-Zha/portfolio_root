---
import SiteLayout from '@/components/layout/SiteLayout.astro';
import Hero from '@/components/home/Hero.astro';
import WorkSection from '@/components/home/WorkSection.astro';
import SystemResearchSection from '@/components/home/SystemResearchSection.astro';
import ExplorationSection from '@/components/home/ExplorationSection.astro';
---

<SiteLayout title="Portfolio" showAmbient={true} isHome={true}>
  <Hero />
  <WorkSection />
  <SystemResearchSection />
  <ExplorationSection />
</SiteLayout>

<style is:global>
  /* ===== Reveal Animation System ===== */

  [data-reveal] {
    opacity: 0;
    transform: translateY(var(--reveal-y, 32px));
    filter: blur(var(--reveal-blur, 8px));
    transition:
      opacity var(--reveal-duration, 1150ms) var(--reveal-ease, cubic-bezier(0.22, 1, 0.36, 1)),
      transform var(--reveal-duration, 1150ms) var(--reveal-ease, cubic-bezier(0.22, 1, 0.36, 1)),
      filter var(--reveal-duration, 1150ms) var(--reveal-ease, cubic-bezier(0.22, 1, 0.36, 1));
    transition-delay: var(--reveal-delay, 0ms);
  }

  [data-reveal].is-revealed {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  /*
   * No-blur mode — for elements containing internal backdrop-filter / foreignObject.
   * blur(0px) still creates a compositor layer that contaminates backdrop-filter sampling.
   * Must use filter: none and exclude filter from the transition entirely.
   */
  [data-reveal][data-reveal-no-blur] {
    filter: none !important;
    transition:
      opacity var(--reveal-duration, 1150ms) var(--reveal-ease, cubic-bezier(0.22, 1, 0.36, 1)),
      transform var(--reveal-duration, 1150ms) var(--reveal-ease, cubic-bezier(0.22, 1, 0.36, 1));
    transition-delay: var(--reveal-delay, 0ms);
  }

  [data-reveal][data-reveal-no-blur].is-revealed {
    filter: none !important;
  }

  /*
   * Reset-transform mode — after animation completes, remove transform entirely.
   * translateY(0) still creates a compositor layer that can pollute backdrop-filter.
   * Use reveal-complete to switch to transform: none.
   */
  [data-reveal][data-reveal-reset-transform].reveal-complete {
    transform: none !important;
    filter: none !important;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      transform: translateY(0);
      filter: blur(0);
      transition-duration: 200ms;
    }
  }
</style>

<script>
  /**
   * Reveal animation system — IntersectionObserver with batch-sort-flush.
   *
   * On mobile, entries that intersect in the same frame are collected, sorted
   * by visual position (top-to-bottom), then revealed in DOM order. This
   * prevents lower elements from "jumping the queue" ahead of upper elements.
   *
   * Markup:
   *   <div data-reveal>Standalone element</div>
   *
   *   <div data-reveal-group="260">
   *     <div data-reveal>Child 1</div>   ← must be DIRECT child of group
   *     <div data-reveal>Child 2</div>
   *   </div>
   *
   * Per-element overrides:
   *   data-reveal-delay="440"       Fixed reveal delay (ms) — overrides all stagger
   *   data-reveal-duration="1100"   Transition duration (ms)
   *   data-reveal-y="36"            TranslateY offset (px)
   *   data-reveal-blur="5"          Blur amount (px)
   *   data-reveal-no-blur           Disable blur (for elements with backdrop-filter)
   *   data-reveal-reset-transform   Clean up compositor layer after animation
   */

  const isMobile = window.matchMedia('(max-width: 768px)').matches;

  const DEFAULTS = {
    duration: isMobile ? 1150 : 1150,
    y:        isMobile ? 36   : 32,
    blur:     isMobile ? 5    : 8,
    stagger:  isMobile ? 260  : 220,
    // Standalone items in same batch get this stagger so they don't all pop at once
    viewportStagger: isMobile ? 140 : 80,
    ease:     'cubic-bezier(0.22, 1, 0.36, 1)',
  };

  // ── applyReveal ──────────────────────────────────────────────────────

  function applyReveal(el, delayMs) {
    // Per-element fixed delay always wins
    if (el.dataset.revealDelay !== undefined) {
      delayMs = parseInt(el.dataset.revealDelay, 10);
    }

    const duration = el.dataset.revealDuration !== undefined
      ? parseInt(el.dataset.revealDuration, 10)
      : DEFAULTS.duration;

    const y = el.dataset.revealY !== undefined
      ? parseInt(el.dataset.revealY, 10)
      : DEFAULTS.y;

    const blur = el.dataset.revealBlur !== undefined
      ? parseInt(el.dataset.revealBlur, 10)
      : DEFAULTS.blur;

    el.style.setProperty('--reveal-duration', duration + 'ms');
    el.style.setProperty('--reveal-y', y + 'px');
    el.style.setProperty('--reveal-blur', blur + 'px');
    el.style.setProperty('--reveal-ease', DEFAULTS.ease);
    el.style.setProperty('--reveal-delay', String(delayMs) + 'ms');
    el.classList.add('is-revealed');

    if (el.hasAttribute('data-reveal-reset-transform')) {
      setTimeout(function () {
        el.classList.add('reveal-complete');
      }, delayMs + duration + 80);
    }
  }

  // ── processGroup ─────────────────────────────────────────────────────

  function processGroup(group) {
    if (group.dataset.revealGroupProcessed === '1') return;
    group.dataset.revealGroupProcessed = '1';

    const staggerMs = parseInt(group.getAttribute('data-reveal-group'), 10) || DEFAULTS.stagger;
    const children = group.querySelectorAll(':scope > [data-reveal]');

    children.forEach(function (child, i) {
      if (child.classList.contains('is-revealed')) return;
      child.dataset.revealProcessed = '1';
      applyReveal(child, i * staggerMs);
      revealObserver.unobserve(child);
    });
  }

  // ── batch-sort-flush scheduler ───────────────────────────────────────

  var pendingEls = [];
  var flushScheduled = false;

  function flushReveals() {
    flushScheduled = false;

    // Deduplicate and filter out already-handled items
    var seen = {};
    var items = [];
    for (var i = 0; i < pendingEls.length; i++) {
      var el = pendingEls[i];
      if (el.dataset.revealProcessed === '1') continue;
      // Deduplicate by a stable key
      var key = el.dataset.revealKey;
      if (!key) {
        // Build a path-based key: tagName + position among siblings
        var path = el.tagName;
        var p = el.parentNode;
        while (p && p !== document.body) {
          if (p.hasAttribute && p.hasAttribute('data-reveal-group')) {
            path = '[group]' + path;
          }
          p = p.parentNode;
        }
        key = path;
        el.dataset.revealKey = key;
      }
      if (seen[key]) continue;
      seen[key] = true;
      items.push(el);
    }
    pendingEls.length = 0;

    if (!items.length) return;

    // On mobile, sort by visual position so upper elements always fire first
    if (isMobile) {
      items.sort(function (a, b) {
        var aTop = a.getBoundingClientRect().top;
        var bTop = b.getBoundingClientRect().top;
        if (Math.abs(aTop - bTop) > 6) return aTop - bTop;
        // Same row — use document order
        return (a.compareDocumentPosition(b) & Node.DOCUMENT_POSITION_FOLLOWING) ? -1 : 1;
      });
    }

    // Track groups already processed in this flush
    var processedGroups = {};
    var standaloneIdx = 0;

    for (var j = 0; j < items.length; j++) {
      var item = items[j];
      if (item.dataset.revealProcessed === '1') continue;

      var group = item.closest('[data-reveal-group]');

      if (group) {
        // Element is inside a group — trigger the whole group once per flush
        var gid = group.dataset.revealGroupId;
        if (!gid) {
          gid = 'g' + Math.random().toString(36).slice(2, 8);
          group.dataset.revealGroupId = gid;
        }
        if (!processedGroups[gid]) {
          processedGroups[gid] = true;
          processGroup(group);
        }
        // This child was either just revealed by processGroup,
        // or the group was already processed earlier. Either way, unobserve.
        if (item.dataset.revealProcessed !== '1') {
          item.dataset.revealProcessed = '1';
          applyReveal(item, 0);
        }
        revealObserver.unobserve(item);
      } else {
        // Standalone — stagger within this batch
        item.dataset.revealProcessed = '1';
        applyReveal(item, standaloneIdx * DEFAULTS.viewportStagger);
        standaloneIdx++;
        revealObserver.unobserve(item);
      }
    }
  }

  function scheduleFlush() {
    if (flushScheduled) return;
    flushScheduled = true;
    requestAnimationFrame(flushReveals);
  }

  // ── IntersectionObserver ─────────────────────────────────────────────

  var revealObserver = new IntersectionObserver(
    function (entries) {
      for (var i = 0; i < entries.length; i++) {
        if (!entries[i].isIntersecting) continue;
        pendingEls.push(entries[i].target);
      }
      scheduleFlush();
    },
    isMobile
      ? { threshold: 0.16, rootMargin: '0px 0px -18% 0px' }
      : { threshold: 0.10, rootMargin: '0px 0px -6% 0px' }
  );

  document.querySelectorAll('[data-reveal]').forEach(function (el) {
    revealObserver.observe(el);
  });
</script>
